# ─────────────────────────────────────────────────────────────
# The Confidential Gallery — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS
# ------------------
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Fill in the values below from your Supabase project
# 3. Restart the dev server: npm run dev
#
# WHERE TO FIND YOUR SUPABASE KEYS
# ----------------------------------
# 1. Go to https://supabase.com and sign in
# 2. Select your project (or create one)
# 3. Go to Project Settings → API
# 4. Copy:
#    - "Project URL"   → NEXT_PUBLIC_SUPABASE_URL
#    - "anon / public" → NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - "service_role"  → SUPABASE_SERVICE_ROLE_KEY  (server-side only, never expose)
#
# ─────────────────────────────────────────────────────────────

# Required — from Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Optional — only needed for admin/delete operations (never expose client-side)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin auth secret (for protecting admin routes server-side)
ADMIN_SECRET=your-secure-admin-secret-here

# Optional — site URL for auth email redirects
# NEXT_PUBLIC_SITE_URL=https://theconfidential.gallery

# Anthropic API key (for future AI painting identification feature)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
